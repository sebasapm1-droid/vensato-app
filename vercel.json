{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/check-subscriptions",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/renew-subscriptions",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/send-charge-emails",
      "schedule": "0 8 * * *"
    }
  ]
}
